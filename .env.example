# Milvus 配置
MILVUS_GRPC_HOST=127.0.0.1
MILVUS_GRPC_PORT=19530
MILVUS_DB_NAME=default
MILVUS_COLLECTION_NAME=frxx
MILVUS_TOKEN=root:Milvus

# LLM API 配置
LLM_API_BASE_URL=<LLM_MODEL_BASE_URL>
LLM_API_KEY=<YOUR_API_KEY>
LLM_MODEL=<YOUR_LLM_MODEL>

# 检索配置
MAX_TOP_K=10
DEFAULT_TOP_K=3

# 文档处理配置
DEFAULT_CHUNK_SIZE=1000
DEFAULT_OVERLAP=50
BATCH_SIZE=32

# 超时配置 (秒)
EMBEDDING_TIMEOUT=30
RETRIEVAL_TIMEOUT=10
LLM_TIMEOUT=60

# 性能配置
MAX_CONCURRENT_REQUESTS=100